# nollmkb 配置 (可选)
#
# 复制为 .env 或导出为环境变量, 可覆盖 config.py 的默认值.
# 不配也能用 (默认相对于 nollmkb/ 同级目录).

# raw 资料目录 (默认: ../inputs)
#NOLLMKB_DOCS_DIR=/path/to/inputs

# ChromaDB 存储目录 (默认: ../chromadb_storage)
#NOLLMKB_KB_DIR=/path/to/chroma

# 哈希文件路径 (默认: <KB_DIR>/file_hashes.json)
#NOLLMKB_HASH_FILE=/path/to/chroma/file_hashes.json

# Wiki 笔记根目录 (默认: ../wiki)
#NOLLMKB_WIKI_DIR=/path/to/wiki

# ChromaDB collection 名 (默认: nollmkb)
#NOLLMKB_COLLECTION=nollmkb

# 日志目录 (默认: ../logs)
#NOLLMKB_LOG_DIR=/path/to/logs

# 日志级别 (默认: INFO)
#NOLLMKB_LOG_LEVEL=INFO

# WebUI 多用户配置 (默认: auth/users.toml)
#NOLLMKB_USERS_FILE=auth/users.toml

# 计算设备 (默认: cuda, 可设为 cpu)
#NOLLMKB_DEVICE=cuda

# 监听地址 (默认: 127.0.0.1，只有本机能访问)
# 远程访问: 跑 tailscale ip -4 拿到 IP，填到下面，不要用 0.0.0.0
#NOLLMKB_HOST=127.0.0.1

# API 认证 (可选, 不设则免认证)
# 生成 hash: python3 -c "import hashlib; print(hashlib.sha256(b'你的密码').hexdigest())"
# 请求时仍用原始密码: Authorization: Bearer 你的密码
#NOLLMKB_API_KEY_HASH=
